<?xml version="1.0" encoding="utf-8"?>
<robot name="real_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="support_pedestal">
    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="1000.0"/> 
      <inertia ixx="41.67" ixy="0" ixz="0" iyy="41.67" iyz="0" izz="41.67"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>
    </collision>
  </link>

  <joint name="support_to_base" type="fixed">
    <parent link="support_pedestal"/>
    <child link="base_link"/>
    <origin xyz="0.15 -0.15 0.6" rpy="0 0 0"/>
  </joint>

  <joint name="support_to_base2" type="fixed">
    <parent link="support_pedestal"/>
    <child link="base_link2"/>
    <origin xyz="0.15 0.2 0.6" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="1.5075E-05 0.0080462 -0.04618" rpy="0 0 0" />
      <mass value="0.7474" />
      <inertia ixx="0.0014688" ixy="-2.4654E-07" ixz="5.5605E-08" 
               iyy="0.0020237" iyz="-2.0837E-07" izz="0.0005961" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://my_arm_description/meshes/base_link.STL" />
      </geometry>
      <material name=""><color rgba="0.86667 0.9098 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.045" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.12 0.19" />
      </geometry>
    </collision>
  </link>

  <joint name="big_arm_revolute_joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="big_arm_link" />
    <axis xyz="0 -1 0" /> 
    <limit lower="0" upper="2.0" effort="1" velocity="1.5"/> 
  </joint>

  <link name="big_arm_link">
    <inertial>
      <origin xyz="0.34149 -0.0085477 -4.2654E-05" rpy="0 0 0" />
      <mass value="0.70079" />
      <inertia ixx="0.00024899" ixy="1.8277E-07" ixz="-1.3062E-09" 
               iyy="0.016819" iyz="3.6418E-09" izz="0.016743" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://my_arm_description/meshes/big_arm_link.STL" />
      </geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0.33 -0.01 0" rpy="0 0 0" />
      <geometry>
        <box size="0.69 0.08 0.055" />
      </geometry>
    </collision>
  </link>

  <link name="big_arm_revolute">
    <inertial>
      <origin xyz="0.003077 -0.039699 1.1329E-05" rpy="0 0 0" />
      <mass value="0.14984" />
      <inertia ixx="4.4359E-05" ixy="1.952E-07" ixz="9.0761E-08" 
               iyy="6.9918E-05" iyz="-1.2284E-08" izz="4.8396E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://my_arm_description/meshes/big_arm_revolute.STL" />
      </geometry>
      <material name=""><color rgba="0.75294 0.75294 0.75294 1" /></material>
    </visual>
  </link>

  <joint name="big_arm_link_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="big_arm_link" />
    <child link="big_arm_revolute" />
    <axis xyz="0 0 0" />
    <limit lower="0" upper="1" effort="1" velocity="0.4" />
  </joint>

  <joint name="small_arm_revolute_joint" type="revolute">
    <origin xyz="0.6591 -0.0005 0" rpy="0 0 0" />
    <parent link="big_arm_link" />
    <child link="small_arm_link" />
    <axis xyz="0 1 0" /> 
    <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1.5" /> 
  </joint>

  <link name="small_arm_link">
    <inertial>
      <origin xyz="0.1839 -0.0095061 -0.0075711" rpy="0 0 0" />
      <mass value="0.29801" />
      <inertia ixx="5.7063E-05" ixy="1.8635E-09" ixz="1.1321E-07" 
               iyy="0.0019018" iyz="-1.0944E-08" izz="0.0018658" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://my_arm_description/meshes/small_arm_link.STL" />
      </geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0.15 -0.01 0" rpy="0 0 0" />
      <geometry>
        <box size="0.3 0.04 0.04" />
      </geometry>
    </collision>
  </link>

  <link name="small_arm_revolute">
    <inertial>
      <origin xyz="-3.71611402421035E-05 -0.00938818868052027 1.73350915055881E-06" rpy="0 0 0" />
      <mass value="0.0196184142019058" />
      <inertia ixx="2.85493872392452E-06" ixy="1.80104567102929E-10" ixz="-2.40901710110046E-11" 
               iyy="4.01221040620382E-06" iyz="-8.40159709133248E-12" izz="2.85442342804465E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://my_arm_description/meshes/small_arm_revolute.STL" />
      </geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
  </link>

  <joint name="small_arm_link_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="small_arm_link" />
    <child link="small_arm_revolute" />
    <axis xyz="0 0 0" />
    <limit lower="0" upper="1" effort="1" velocity="0.4" />
  </joint>

  <link name="base_link2">
    <inertial>
      <origin xyz="1.5075E-05 0.0080462 -0.04618" rpy="0 0 0" />
      <mass value="0.7474" />
      <inertia ixx="0.0014688" ixy="-2.4654E-07" ixz="5.5605E-08" 
               iyy="0.0020237" iyz="-2.0837E-07" izz="0.0005961" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://my_arm_description/meshes/base_link.STL" />
      </geometry>
      <material name=""><color rgba="0.86667 0.9098 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.045" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.12 0.19" />
      </geometry>
    </collision>
  </link>

  <joint name="big_arm_revolute_joint2" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link2" />
    <child link="big_arm_link2" />
    <axis xyz="0 -1 0" /> 
    <limit lower="0" upper="1.5708" effort="1" velocity="0.4" /> 
  </joint>

  <link name="big_arm_link2">
    <inertial>
      <origin xyz="0.34149 -0.0085477 -4.2654E-05" rpy="0 0 0" />
      <mass value="0.70079" />
      <inertia ixx="0.00024899" ixy="1.8277E-07" ixz="-1.3062E-09" 
               iyy="0.016819" iyz="3.6418E-09" izz="0.016743" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://my_arm_description/meshes/big_arm_link.STL" />
      </geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0.33 -0.01 0" rpy="0 0 0" />
      <geometry>
        <box size="0.69 0.08 0.055" />
      </geometry>
    </collision>
  </link>


  <link name="suction_cup_link">
    <collision>
      <origin xyz="0 0 -0.0245" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.037" length="0.044" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.0245" rpy="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="0.00010126" ixy="0" ixz="0" 
               iyy="0.00010126" iyz="0" izz="0.0001225" />
    </inertial>
  </link>

  <joint name="suction_joint" type="prismatic">
    <parent link="small_arm_link" />
    <child link="suction_cup_link" />
    <origin xyz="0.275 -0.01 -0.019" rpy="0 0 0" /> 
    <axis xyz="0 0 1" />
    <limit lower="-2.0" upper="3.0" effort="10" velocity="0.4" />
  </joint>

  <!-- 2. 夹爪 -->
  <link name="gripper_link2">
    <visual>
      <origin xyz="0 0 -0.0245" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.15 0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0245" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.15 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.0245" rpy="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="0.00010126" ixy="0" ixz="0" 
               iyy="0.00010126" iyz="0" izz="0.0001225" />
    </inertial>
  </link>


  <joint name="gripper_joint" type="prismatic">
    <parent link="big_arm_link2" />
    <child link="gripper_link2" />
    <origin xyz="0.7 -0.01 -0.0" rpy="0 0 0" /> 
    <axis xyz="0 0 1" />
    <limit lower="-2.0" upper="3.0" effort="10" velocity="0.4" />
  </joint>


  <ros2_control name="RealArmSystem" type="system">


    <hardware>
      <plugin>my_arm_hardware/ArmHardwareInterface</plugin>
      <param name="port">/dev/ttyUSB0</param>
      <param name="baudrate">115200</param>
    </hardware>

    <!-- <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>  -->

    

    <joint name="big_arm_revolute_joint">
      <param name="motor_id">1</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>


    <joint name="small_arm_revolute_joint">
      <param name="motor_id">2</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  
    <joint name="big_arm_revolute_joint2">
      <param name="motor_id">3</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>


    <joint name="suction_joint">
      <param name="motor_id">4</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="gripper_joint">
      <param name="motor_id">5</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
      
  </ros2_control>

  <!-- <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find real_arm_moveit_config)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo> -->

</robot>