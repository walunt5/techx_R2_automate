<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="real_arm">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />
    <xacro:arg name="use_sim" default="true"/>

    <!-- Import real_arm urdf file -->
    <xacro:include filename="$(find my_arm_description)/urdf/real_arm.urdf.xacro"/>


</robot>
